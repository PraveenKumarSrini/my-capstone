# Required — PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/devpulse

# Required — NextAuth secret (generate: openssl rand -base64 32)
NEXTAUTH_SECRET=your-32-char-secret-here

# Required — public base URL of the app
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth App credentials (create at https://github.com/settings/applications/new)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# AES-256-GCM encryption key for tokens + secrets at rest (generate: openssl rand -hex 32)
ENCRYPTION_KEY=your-32-byte-hex-string-here

# Public base URL for GitHub webhook delivery (use ngrok in dev)
WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok.io

# Optional — log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Optional — reconciliation interval in ms (default: 30 min)
SYNC_INTERVAL_MS=1800000
